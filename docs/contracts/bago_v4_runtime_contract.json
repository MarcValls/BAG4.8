{
  "contract_id": "bago.v4.runtime.session-first",
  "contract_version": "4.8.0",
  "scope": "repository",
  "source_of_truth": [
    "docs\\COMMUNITY.md",
    "docs\\contracts\\bago_v4_repl_contract.md",
    "docs\\contracts\\bago_v4_pipeline_contract.md",
    "docs\\contracts\\bago_v4_evidence_contract.md",
    "docs\\contracts\\bago_v4_knowledge_contract.md",
    "docs\\contracts\\bago_v4_governance_contract.md",
    "docs\\contracts\\bago_v4_engineering_contract.md"
  ],
  "validation_commands": [
    "python test_e2e.py",
    "python bago_core\\cli.py evidence --test",
    "python -m pytest tests\\test_plan_engine_contract.py -q"
  ],
  "required_repository_roots": [
    ".bago",
    "bago_core",
    "docs",
    "MANUAL.md",
    "test_e2e.py"
  ],
  "runtime_layout": {
    "config": ".bago\\config.json",
    "state_root": ".bago\\state",
    "knowledge_db": ".bago\\state\\knowledge.db",
    "sessions_root": ".bago\\state\\sessions",
    "session_bundle_files": [
      "context.jsonl",
      "timeline.jsonl",
      "tokens.json",
      "meta.json"
    ],
    "saved_session_metadata": ".bago\\state\\sessions\\<session_id>.json"
  },
  "runtime_invariants": [
    "Toda sesion debe tener un session_id estable y persistible.",
    "Un guardado valido debe producir artefactos de sesion en disco.",
    "El cambio de provider o modelo no debe invalidar la identidad de la sesion.",
    "La knowledge base debe poder anadir, listar y buscar contenido persistente.",
    "La validacion simulada debe ejecutarse sin provider externo.",
    "La validacion real debe requerir un provider vivo y una respuesta no vacia."
  ],
  "provider_contract": {
    "minimum_capabilities": [
      "health_check",
      "list_models",
      "chat"
    ],
    "real_mode_requirements": [
      "provider configurado",
      "modelo resoluble",
      "respuesta util no vacia"
    ]
  },
  "evidence_generator": {
    "command": "python bago_core\\cli.py evidence",
    "modes": [
      "simulated",
      "real"
    ],
    "example_output": "docs\\evidence\\example_bundle"
  }
}
