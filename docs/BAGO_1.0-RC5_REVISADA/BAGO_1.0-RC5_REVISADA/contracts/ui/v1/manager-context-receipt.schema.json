{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bago://contracts/ui/v1/manager-context-receipt",
  "title": "ManagerContextReceipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "manager_context_id",
    "request_id",
    "execution_id",
    "received_fields",
    "admitted_fields",
    "rejected_fields",
    "consumed_fields",
    "consumption_status",
    "receipt_hash"
  ],
  "properties": {
    "contract_version": {
      "type": "string"
    },
    "manager_context_id": {
      "type": "string"
    },
    "request_id": {
      "type": "string"
    },
    "execution_id": {
      "type": "string"
    },
    "received_fields": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "admitted_fields": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rejected_fields": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "consumed_fields": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "prompt_section_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "model_input_hash": {
      "type": [
        "string",
        "null"
      ]
    },
    "consumption_status": {
      "enum": [
        "confirmed",
        "partial",
        "rejected",
        "unknown",
        "contract_failed"
      ]
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "receipt_hash": {
      "type": "string",
      "minLength": 16
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "consumption_status": {
            "const": "confirmed"
          }
        }
      },
      "then": {
        "properties": {
          "consumed_fields": {
            "minItems": 1
          },
          "model_input_hash": {
            "type": "string",
            "minLength": 16
          }
        }
      }
    }
  ]
}
