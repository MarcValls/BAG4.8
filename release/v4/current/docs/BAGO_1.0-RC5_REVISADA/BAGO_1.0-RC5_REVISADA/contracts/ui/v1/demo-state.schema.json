{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bago://contracts/ui/v1/demo-state",
  "title": "DemoState",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "demo_mode",
    "synthetic_data",
    "effects_disabled",
    "persistent_label_required",
    "backend_connected"
  ],
  "properties": {
    "contract_version": {
      "type": "string"
    },
    "demo_mode": {
      "const": true
    },
    "demo_id": {
      "type": "string"
    },
    "synthetic_data": {
      "const": true
    },
    "effects_disabled": {
      "const": true
    },
    "persistent_label_required": {
      "const": true
    },
    "backend_connected": {
      "type": "boolean"
    },
    "allowed_demo_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "forbidden_operational_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
